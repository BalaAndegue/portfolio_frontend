DATABASE_URL="file:./dev.db"

# URL publique de ton site (remplace par ton vrai domaine Vercel ou custom)
NEXTAUTH_URL="https://portfolio-frontend-7tzzqqv8b-bala-andegues-projects.vercel.app"

# NEXTAUTH_SECRET : obligatoire en production.
# Ne pas mettre la vraie valeur ici — la définir dans :
#   Vercel Dashboard → Settings → Environment Variables → NEXTAUTH_SECRET
# Pour en générer une : openssl rand -base64 32
# Sans cette variable, les sessions JWT sont invalides après chaque déploiement.
