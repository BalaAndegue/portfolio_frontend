# ─────────────────────────────────────────────────────────────
# Copie ce fichier en .env et remplis les valeurs manquantes.
# Ne commite JAMAIS ton .env (il est dans .gitignore).
# ─────────────────────────────────────────────────────────────

# ── Base de données ──────────────────────────────────────────
# SQLite local (dev). Sur Vercel, le chemin est résolu
# relativement à prisma/schema.prisma → pointe sur prisma/dev.db
DATABASE_URL="file:./dev.db"

# ── NextAuth ─────────────────────────────────────────────────
# URL publique de l'application
#   - Local  : http://localhost:3000
#   - Vercel : https://<ton-projet>.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Secret de signature des tokens JWT.
# OBLIGATOIRE en production, sinon le login plante.
# Génère-en un avec : openssl rand -base64 32
# Sur Vercel → Settings → Environment Variables → ajouter NEXTAUTH_SECRET
NEXTAUTH_SECRET="change-moi-avec-openssl-rand-base64-32"
